APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Локально: http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Продакшен (HTTPS): APP_URL=https://studentportfolio.ru, FRONTEND_URL=https://studentportfolio.ru

# Редирект HTTP→HTTPS и генерация URL с https (по умолчанию true при APP_ENV=production).
# Локально с http оставьте APP_ENV=local или явно: FORCE_HTTPS=false
# FORCE_HTTPS=true

# CORS / Sanctum SPA (comma-separated origins)
# Продакшен: добавьте https://studentportfolio.ru,https://www.studentportfolio.ru
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_SUPPORTS_CREDENTIALS=true
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# Path to pdftotext binary (optional; Docker image includes poppler-utils)
PDFTOTEXT_PATH=

# Email главного админа (удаление через API запрещено)
PRIMARY_ADMIN_EMAIL=admin@example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL 18. pgAdmin: тот же хост/порт. На Windows при сбоях с 127.0.0.1 попробуйте DB_HOST=localhost.
# Если PHP/Laravel запускаются В Docker: DB_HOST=postgres (имя сервиса в docker-compose).
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=portfolio
DB_USERNAME=portfolio
DB_PASSWORD=secret

# Резерв: SQLite
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Превью и галерея: s3 = Yandex Object Storage (рекомендуется), public = локальный диск
PROJECT_MEDIA_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Yandex Object Storage (S3-совместимый API)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=
AWS_URL=https://storage.yandexcloud.net/portfoliodb
AWS_ENDPOINT=https://storage.yandexcloud.net
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_SSL_VERIFY=true

VITE_APP_NAME="${APP_NAME}"
